---
import { getCollection, getEntry } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import config, { monolocale } from "$config";
import Base from "$layouts/Base.astro";
import Heatmap from "$components/Heatmap.svelte";
import Icon from "$components/Icon.svelte";
import i18nit from "$i18n";

export async function getStaticPaths() {
	// Create path for each locale, omitting default locale from URL
	return config.i18n.locales.map(locale => ({ params: { locale: config.i18n.defaultLocale === locale ? undefined : locale } }));
}

const { locale = config.i18n.defaultLocale } = Astro.params;

const t = i18nit(locale);

// Get published notes for current locale
const notes = await getCollection("note", note => {
	// Filter by publication status and locale
	let published = !note.data.draft;
	let localed = monolocale || note.id.split("/")[0] === locale;

	// Filter published notes by current locale
	return published && localed;
});

// Get published jottings for current locale
const jottings = await getCollection("jotting", jotting => {
	// Assign type property
	Reflect.set(jotting, "type", "jotting");

	// Check monolocale setup or extract language to match locale
	let localed = monolocale || jotting.id.split("/")[0] === locale;

	// Filter published notes by current locale
	return !jotting.data.draft && localed;
});

const localePrefix = monolocale ? "" : `${locale}/`;
const profileEntry = await getEntry("information", `${localePrefix}profile`);
const profile = profileEntry?.data as {
	name: string;
	shortName: string;
	avatar: string;
	email: string;
	github: string;
	homepage: string;
	location: string;
	affiliation: string;
	status: string;
	headline: string;
	bio: string;
	interests: { title: string; detail: string }[];
	focus: string[];
	education: { institution: string; status: string; period: string; note: string };
	skillGroups: { name: string; items: string[] }[];
};

const writingTotal = notes.length + jottings.length;
---

<Base title={t("navigation.home")} {locale} description={profile.headline}>
	<main class="home-shell flex flex-col gap-12 grow">
		<header class="grid items-center gap-8 md:grid-cols-[minmax(0,1fr)_16rem]">
			<section class="flex flex-col gap-5">
				<p class="font-mono text-sm text-secondary">{profile.affiliation} / {profile.status}</p>
				<div class="flex flex-col gap-3">
					<h1 class="text-4xl sm:text-5xl leading-tight">{profile.name}</h1>
					<p class="max-w-2xl text-xl leading-relaxed text-secondary">{profile.headline}</p>
				</div>
				<p class="max-w-2xl leading-8">{profile.bio}</p>
				<nav aria-label="Profile links" class="flex flex-wrap gap-3">
					<a href={`mailto:${profile.email}`} class="profile-link">
						<Icon name="lucide--mail" />
						Email
					</a>
					<a href={profile.github} target="_blank" rel="noopener noreferrer" class="profile-link">
						<Icon name="simple-icons--github" />
						GitHub
					</a>
					<a href={getRelativeLocaleUrl(locale, "/about")} class="profile-link">
						<Icon name="lucide--at-sign" />
						About
					</a>
				</nav>
			</section>

			<aside class="flex md:justify-end">
				<div class="profile-plate flex w-full max-w-64 flex-col gap-4 border-s-2 ps-5">
					<object data={profile.avatar} type="image/png" aria-label={`${profile.name} avatar`} class="h-28 w-28 overflow-hidden rounded-full border border-shadow">
						<img src="/favicon.svg" alt={`${profile.name} avatar`} data-nozoom class="h-full w-full object-cover" />
					</object>
					<div class="flex flex-col gap-1">
						<strong class="text-xl">{profile.shortName}</strong>
						<span class="text-sm text-secondary">{profile.location}</span>
						<a href={profile.homepage} target="_blank" rel="noopener noreferrer" class="link text-sm font-mono text-remark">{profile.homepage.replace("https://", "")}</a>
					</div>
				</div>
			</aside>
		</header>

		<section aria-labelledby="research-interests" class="home-section">
			<div class="section-heading">
				<span class="section-mark research-mark"></span>
				<h2 id="research-interests">Research Interests</h2>
			</div>
			<div class="grid gap-4 sm:grid-cols-2">
				{profile.interests.map(interest => (
					<article class="interest-item">
						<h3>{interest.title}</h3>
						<p>{interest.detail}</p>
					</article>
				))}
			</div>
		</section>

		<section aria-labelledby="current-focus" class="home-section">
			<div class="section-heading">
				<span class="section-mark focus-mark"></span>
				<h2 id="current-focus">Current Focus</h2>
			</div>
			<ol class="grid gap-3">
				{profile.focus.map((item, index) => (
					<li class="focus-item">
						<span>{String(index + 1).padStart(2, "0")}</span>
						<p>{item}</p>
					</li>
				))}
			</ol>
		</section>

		<section class="grid gap-10 md:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)]">
			<div aria-labelledby="education" class="home-section">
				<div class="section-heading">
					<span class="section-mark education-mark"></span>
					<h2 id="education">Education</h2>
				</div>
				<div class="flex flex-col gap-2 border-s border-weak ps-4">
					<strong>{profile.education.institution}</strong>
					<span class="font-mono text-sm text-secondary">{profile.education.period} / {profile.education.status}</span>
					<p class="leading-7 text-secondary">{profile.education.note}</p>
				</div>
			</div>

			<div aria-labelledby="skills-tools" class="home-section">
				<div class="section-heading">
					<span class="section-mark skills-mark"></span>
					<h2 id="skills-tools">Skills / Tools</h2>
				</div>
				<div class="grid gap-4 sm:grid-cols-3">
					{profile.skillGroups.map(group => (
						<section class="skill-group">
							<h3>{group.name}</h3>
							<ul>
								{group.items.map(item => <li>{item}</li>)}
							</ul>
						</section>
					))}
				</div>
			</div>
		</section>

		<section aria-labelledby="writing-activity" class="home-section writing-section">
			<div class="section-heading">
				<span class="section-mark writing-mark"></span>
				<div>
					<h2 id="writing-activity">Writing Activity</h2>
					<p class="mt-1 text-sm text-secondary">{writingTotal} 则公开记录 · 近期写作频率</p>
				</div>
			</div>
			<div class="overflow-x-auto pb-2">
				<Heatmap {locale} {notes} {jottings} showEntries={false} />
			</div>
		</section>
	</main>
</Base>

<style>
	.home-shell {
		--home-green: #4f766b;
		--home-blue: #456f83;
		--home-warm: #8a6f3a;
		--home-rose: #8a5d63;
	}

	:global([data-theme="dark"]) .home-shell {
		--home-green: #7aa899;
		--home-blue: #83a8ba;
		--home-warm: #b7a067;
		--home-rose: #bd8790;
	}

	.profile-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		border-bottom: 2px solid var(--primary-color);
		padding: 0.25rem;
		font-family: var(--font-mono);
		font-size: 0.875rem;
		transition: color 0.15s ease-in-out;
	}

	.profile-link:hover {
		color: var(--secondary-color);
	}

	.profile-plate {
		border-inline-start-color: var(--home-green);
	}

	.home-section {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.section-heading {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		border-bottom: 1px solid var(--weak-color);
		padding-bottom: 0.5rem;
	}

	.section-heading h2 {
		font-size: 1.5rem;
	}

	.section-mark {
		width: 0.75rem;
		height: 0.75rem;
		flex-shrink: 0;
		border-radius: 9999px;
	}

	.research-mark {
		background: var(--home-green);
	}

	.focus-mark {
		background: var(--home-blue);
	}

	.education-mark {
		background: var(--home-warm);
	}

	.skills-mark {
		background: var(--home-rose);
	}

	.writing-mark {
		background: var(--home-green);
	}

	.interest-item {
		border-inline-start: 1px solid var(--weak-color);
		padding-inline-start: 1rem;
	}

	.interest-item h3,
	.skill-group h3 {
		margin-bottom: 0.5rem;
		font-size: 1.125rem;
	}

	.interest-item p {
		color: var(--secondary-color);
		line-height: 1.75rem;
	}

	.focus-item {
		display: grid;
		grid-template-columns: 2.5rem minmax(0, 1fr);
		align-items: start;
		gap: 0.75rem;
		border-bottom: 1px dashed var(--weak-color);
		padding-bottom: 0.75rem;
	}

	.focus-item span {
		color: var(--remark-color);
		font-family: var(--font-mono);
		font-size: 0.875rem;
	}

	.focus-item p {
		line-height: 1.75rem;
	}

	.skill-group {
		border-top: 1px solid var(--weak-color);
		padding-top: 0.75rem;
	}

	.skill-group ul {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		color: var(--secondary-color);
		font-size: 0.875rem;
		line-height: 1.5rem;
	}

	.skill-group li {
		list-style: none;
	}

	.skill-group li::before {
		content: "/";
		margin-inline-end: 0.4rem;
		color: var(--home-blue);
	}

	.writing-section {
		margin-bottom: 1rem;
	}
</style>
